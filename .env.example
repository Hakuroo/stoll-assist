APP_ENV=development
APP_NAME=stoll-assist
API_PORT=8000

DATABASE_URL=postgresql+psycopg://stoll:stoll@postgres:5432/stoll_assist
REDIS_URL=redis://redis:6379/0

S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=stoll-assist
S3_REGION=us-east-1

META_VERIFY_TOKEN=replace-me
META_APP_SECRET=replace-me
META_ACCESS_TOKEN=replace-me
META_PHONE_NUMBER_ID=replace-me
META_API_VERSION=vXX.X

OPENAI_API_KEY=replace-me
OPENAI_CLASSIFIER_MODEL=gpt-5.4-nano
OPENAI_GENERATION_MODEL=gpt-5.4-mini
OPENAI_VERIFIER_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

DEFAULT_TENANT_SLUG=grupo-stoll
AGENT_NAME=Agustina
AGENT_DISCLOSURE=Soy Agustina, asistente digital del equipo de Grupo Stöll.

WEBHOOK_QUEUE_NAME=stoll:webhooks
WORKER_BLOCK_TIMEOUT_SECONDS=5

KNOWLEDGE_CONFIG_PATH=/app/config/stoll/knowledge
